// Modifique o Hello World para exibir: - Seu nome - Sua cidade - A frase "Pronto para aprender ADVPL!"

// Forma 1

FUNCTION Main()
    
    LOCAL cNome := "Vinícius Nóbrega"
    LOCAL cCidade := "Guarulhos"

    QOut("- " + cNome + " - " + cCidade +  " - Pronto para aprender ADVPL!")

RETURN NIL

